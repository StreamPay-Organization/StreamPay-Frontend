# StreamPay frontend environment variables
# Copy this file to .env and adjust as needed.

# Display name for the app
VITE_APP_NAME=StreamPay

# Stellar network the (mock) wallet pretends to use: TESTNET | PUBLIC
VITE_STELLAR_NETWORK=TESTNET

# Simulated network latency in milliseconds for the mock services
VITE_MOCK_LATENCY_MS=600

# Soroban RPC endpoint (unused by the mock build, kept for parity)
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
